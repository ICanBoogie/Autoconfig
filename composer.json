{
  "name": "icanboogie/autoconfig",
  "type": "composer-plugin",
  "license": "BSD-3-Clause",
  "description": "Automatically gather low-level configuration information for ICanBoogie",
  "require": {
    "php": ">=8.1",
    "composer-plugin-api": "^2.0"
  },
  "require-dev": {
    "composer/composer": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "ICanBoogie\\Autoconfig\\": "lib"
    }
  },
  "extra": {
    "class": "ICanBoogie\\Autoconfig\\Composer\\AutoconfigPlugin"
  }
}
